{
  "id": "ttxworks",
  "title": "TTXWorks",
  "description": "A narrative framework for running tabletop exercises as structured, consequence-driven simulations.",
  "version": "0.2.0",
  "compatibility": {
    "minimum": "12",
    "verified": "13",
    "maximum": "13"
  },
  "authors": [
    {
      "name": "TTXWorks"
    }
  ],
  "esmodules": ["ttxworks.mjs"],
  "styles": ["styles/ttxworks.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [
    {
      "name": "skills",
      "label": "TTXWorks Skills",
      "path": "packs/skills/skills",
      "type": "Item",
      "system": "ttxworks"
    },
    {
      "name": "assets",
      "label": "TTXWorks Assets",
      "path": "packs/assets/assets",
      "type": "Item",
      "system": "ttxworks"
    }
  ],
  "manifest": "https://raw.githubusercontent.com/Shadoghast/ttxworks/main/system.json",
  "download": "https://github.com/Shadoghast/ttxworks/archive/refs/tags/v0.2.0.zip",
  "url": "https://github.com/Shadoghast/ttxworks",
  "socket": true,
  "initiative": "1d100",
  "grid": {
    "distance": 5,
    "units": "ft"
  },
  "primaryTokenAttribute": "focus.value",
  "secondaryTokenAttribute": "stress.value",
  "documentTypes": {
    "Actor": {
      "individual": {},
      "team": {},
      "adversary": {},
      "node": {},
      "event": {},
      "action": {}
    },
    "Item": {
      "skill": {},
      "asset": {},
      "clock": {},
      "effect": {}
    }
  }
}
