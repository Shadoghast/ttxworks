{
  "id": "ttxworks",
  "title": "TTXWorks: A Narrative Framework for Tabletop Exercises",
  "description": "A narrative framework for running tabletop exercises as structured, consequence-driven simulations. Inspired by Blades in the Dark.",
  "version": "0.1.0",
  "compatibility": {
    "minimum": "12",
    "verified": "12",
    "maximum": "13"
  },
  "authors": [
    {
      "name": "TTXWorks"
    }
  ],
  "esmodules": ["ttxworks.mjs"],
  "styles": ["styles/ttxworks.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [
    {
      "name": "skills",
      "label": "TTXWorks Skills",
      "path": "packs/skills/skills",
      "type": "Item",
      "system": "ttxworks"
    },
    {
      "name": "assets",
      "label": "TTXWorks Assets",
      "path": "packs/assets/assets",
      "type": "Item",
      "system": "ttxworks"
    }
  ],
  "socket": false,
  "initiative": "1d100",
  "grid": {
    "distance": 5,
    "units": "ft"
  },
  "primaryTokenAttribute": "focus.value",
  "secondaryTokenAttribute": "stress.value",
  "documentTypes": {
    "Actor": {
      "individual": {},
      "team": {},
      "adversary": {},
      "node": {}
    },
    "Item": {
      "skill": {},
      "asset": {},
      "clock": {},
      "effect": {}
    }
  }
}
