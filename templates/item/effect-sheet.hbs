<form class="ttxworks sheet item effect" autocomplete="off">
  <header class="sheet-header item-header">
    <div class="header-fields" style="width:100%">
      <h1><input name="name" type="text" value="{{item.name}}" placeholder="Effect Name (e.g. Obfuscation, Network Isolated)"/></h1>
    </div>
  </header>

  <section class="sheet-body item-body">
    <div class="form-row">
      <div class="form-group">
        <label>TN Modifier (%)</label>
        <input type="number" name="system.modifier" value="{{system.modifier}}"
               placeholder="e.g. -10 or +5"/>
        <span class="hint">Positive = benefit, Negative = penalty</span>
      </div>
      <div class="form-group">
        <label>Duration</label>
        <select name="system.duration">
          {{#each durationChoices as |d|}}
          <option value="{{d}}" {{#if (eq d ../system.duration)}}selected{{/if}}>{{capitalize d}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Duration (Rounds, if applicable)</label>
      <input type="number" name="system.durationRounds" value="{{system.durationRounds}}"
             placeholder="Leave blank for permanent / until-cleared" min="1"/>
    </div>

    <div class="form-group">
      <label>Source</label>
      <input type="text" name="system.source" value="{{system.source}}"
             placeholder="Who or what created this effect?"/>
    </div>

    <div class="form-group full-width">
      <label>Description</label>
      <textarea name="system.description" rows="4"
                placeholder="Narrative description of what this effect represents">{{system.description}}</textarea>
    </div>
  </section>
</form>
