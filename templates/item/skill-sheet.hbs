<form class="ttxworks sheet item skill" autocomplete="off">
  <header class="sheet-header item-header">
    <img class="item-img" src="{{item.img}}" title="{{item.name}}" data-edit="img"/>
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{item.name}}" placeholder="Skill Name"/></h1>
      <div class="header-row">
        <label>Category</label>
        <select name="system.category">
          {{#each skillCategories as |cat|}}
          <option value="{{cat}}" {{#if (eq cat ../system.category)}}selected{{/if}}>{{cat}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </header>

  <section class="sheet-body item-body">
    <div class="form-group">
      <label>Bonus (% TN when relevant)</label>
      <input type="number" name="system.bonus" value="{{system.bonus}}" min="0" max="30"/>
      <span class="hint">Default: +10%</span>
    </div>
    <div class="form-group full-width">
      <label>Description</label>
      {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>
  </section>
</form>
